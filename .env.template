# ==========================================
# --- POSTGRES (Основная База Данных) ---
# ==========================================
# Имя основной (дефолтной) базы данных, которая создается при первом запуске контейнера.
POSTGRES_DB=pachamama
# Имя главного пользователя (суперюзера) PostgreSQL. От его лица скрипт инициализации будет создавать остальные БД.
POSTGRES_USER=pachamama_admin
# Пароль суперюзера БД. 
# ВНИМАНИЕ: Обязательно замените на сложный, криптографически стойкий пароль перед деплоем на боевой сервер!
POSTGRES_PASSWORD=admin

# ==========================================
# --- PGADMIN (Панель управления БД) ---
# ==========================================
# Email, который будет использоваться в качестве логина для входа в веб-интерфейс PgAdmin.
PGADMIN_DEFAULT_EMAIL=admin@mail.com
# Пароль для входа в веб-интерфейс PgAdmin. Также настоятельно рекомендуется заменить на надежный.
PGADMIN_DEFAULT_PASSWORD=admin

# ==========================================
# --- URLS (Внешние адреса сервисов) ---
# ==========================================
# Эти переменные критически важны для корректной работы сервисов извне.
# Замените test.com на ваш реальный домен. После настройки SSL в Nginx Proxy Manager используйте протокол https://.

# Внешний публичный адрес n8n. 
# Нужен движку для генерации правильных ссылок на Webhook-узлы внутри сценариев (чтобы внешние сервисы могли отправлять данные в ваш n8n).
N8N_WEBHOOK_URL=http://n8n.test.com

# Внешний публичный адрес Baserow. 
# Без его точного указания сервис не сможет загружать статические файлы (картинки, стили фронтенда) и будет отклонять API-запросы из-за CORS.
BASEROW_PUBLIC_URL=http://baserow.test.com

# ==========================================
# --- СИСТЕМНЫЕ НАСТРОЙКИ ---
# ==========================================
# Часовой пояс (Тайм-зона). Применяется ко всем ключевым сервисам: NPM, PgAdmin, Baserow, NocoDB и n8n.
# Гарантирует, что время создания записей в базах данных, время в логах и расписания планировщиков задач (cron-узлы в n8n) будут совпадать с вашим реальным временем.
TZ=Europe/Moscow

# ==========================================
# --- ИЗОЛИРОВАННЫЕ БАЗЫ ДАННЫХ ---
# ==========================================
# Имена отдельных баз данных для каждого сервиса. 
# Наш кастомный скрипт init-multiple-dbs.sh автоматически прочитает эти переменные и создаст нужные БД при самом первом запуске.
# Такое разделение необходимо для архитектурной чистоты: чтобы сервисы не мешали друг другу и не имели доступа к чужим таблицам.

# БД для хранения маршрутов (proxy hosts), списков доступа и путей к сертификатам Nginx Proxy Manager
DB_NPM_NAME=pachamama_npm_db
# БД для сохранения созданных сценариев (workflows), зашифрованных учетных данных (credentials) и истории выполнений задач в n8n
DB_N8N_NAME=pachamama_n8n_db
# БД для хранения системной информации, пользователей и метаданных интерфейса NocoDB
DB_NOCODB_NAME=pachamama_nocodb_db
# БД для хранения пользовательских пространств, таблиц, колонок и самих данных, введенных через интерфейс Baserow
DB_BASEROW_NAME=pachamama_baserow_db

# ==========================================
# --- НАСТРОЙКИ ЛОГИРОВАНИЯ (Docker) ---
# ==========================================
# Настройки драйвера json-file, применяемые ко всем контейнерам проекта. Спасают сервер от переполнения диска (Out of space).

# Максимальный размер одного файла логов для каждого контейнера до его ротации (сжатия/удаления). 
LOG_MAX_SIZE=100m
# Максимальное количество файлов логов, которые хранятся для одного контейнера единовременно (самые старые удаляются).
LOG_MAX_FILES=3